generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum Role {
  STUDENT
  ADMIN
  MENTOR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemStatus {
  UNSOLVED
  ATTEMPTED
  SOLVED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password      String?
  googleId      String?   @unique
  role          Role      @default(STUDENT)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile        Profile?
  dsaProblems    DSAProblem[]
  resumes        Resume[]
  interviews     InterviewSession[]
  streaks        Streak[]
  readinessScore ReadinessScore?
  dailyPlans     DailyPlan[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          String[]
  targetCompanies String[]
  bio             String?
  linkedinUrl     String?
  githubUrl       String?
  college         String?
  graduationYear  Int?
}

model DSAProblem {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  topic      String
  difficulty Difficulty
  status     ProblemStatus @default(UNSOLVED)
  platform   String?
  notes      String?
  solvedAt   DateTime?
  createdAt  DateTime      @default(now())
}

model Resume {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl    String
  version    Int      @default(1)
  atsScore   Float?
  aiAnalysis Json?
  createdAt  DateTime @default(now())
}

model InterviewSession {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company            String
  role               String
  date               DateTime
  audioUrl           String?
  notes              String?
  questionsAsked     String[]
  overallScore       Float?
  confidenceScore    Float?
  communicationScore Float?
  conceptsMissed     String[]
  aiSummary          Json?
  actionPlan         String?
  createdAt          DateTime @default(now())
}

model Streak {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  activity  String
  createdAt DateTime @default(now())

  @@unique([userId, date, activity])
}

model ReadinessScore {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dsaScore       Float    @default(0)
  resumeScore    Float    @default(0)
  interviewScore Float    @default(0)
  aptitudeScore  Float    @default(0)
  overallScore   Float    @default(0)
  readyFor       String[]
  improveFor     String[]
  updatedAt      DateTime @updatedAt
}

model DailyPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdDate String
  plan        Json
  createdAt   DateTime @default(now())

  @@unique([userId, createdDate])
}