generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  MENTOR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemStatus {
  UNSOLVED
  ATTEMPTED
  SOLVED
}

enum DSAProblemSource {
  MANUAL
  LEETCODE
}

enum InterviewRoundType {
  HR
  TECHNICAL
  MANAGERIAL
  APTITUDE
  GROUP_DISCUSSION
  SYSTEM_DESIGN
  CODING
  OTHER
}

enum InterviewResult {
  PENDING
  SELECTED
  REJECTED
  ON_HOLD
  NO_RESPONSE
}

enum InterviewSourceType {
  MANUAL
  AUDIO
  VIDEO
}

enum InterviewAnalysisStatus {
  DRAFT
  ANALYZED
}

enum FeedbackType {
  BUG_REPORT
  FEATURE_REQUEST
  SUGGESTION
  CONTACT_OWNER
  OTHER
}

enum FeedbackStatus {
  OPEN
  REVIEWED
  RESOLVED
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  name        String
  password    String?
  googleId    String? @unique
  firebaseUid String? @unique
  role        Role    @default(STUDENT)
  avatarUrl   String?

  emailVerified              Boolean   @default(false)
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile          Profile?
  dsaProblems      DSAProblem[]
  resumes          Resume[]
  interviews       InterviewSession[]
  streaks          Streak[]
  readinessScore   ReadinessScore?
  dailyPlans       DailyPlan[]
  readinessHistory ReadinessHistory[]
  plan             Plan               @default(FREE)
  payments         Payment[]
  feedback         Feedback[]

  @@index([emailVerificationTokenHash])
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          String[]
  targetCompanies String[]
  bio             String?
  linkedinUrl     String?
  githubUrl       String?
  college         String?
  graduationYear  Int?
}

model DSAProblem {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core problem details
  title      String
  topic      String
  pattern    String?
  difficulty Difficulty
  status     ProblemStatus @default(UNSOLVED)

  // Platform and source
  platform   String?
  problemUrl String?
  source     DSAProblemSource @default(MANUAL)
  externalId String?
  importedAt DateTime?

  // Placement metadata
  companies String[] @default([])
  notes     String?

  // Solving progress
  solveCount Int       @default(0)
  solvedAt   DateTime?

  // Revision engine
  revisionCount  Int       @default(0)
  lastRevisedAt  DateTime?
  nextRevisionAt DateTime?

  revisions DSARevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, topic])
  @@index([userId, pattern])
  @@index([userId, difficulty])
  @@index([userId, nextRevisionAt])
  @@index([source])
}

model DSARevision {
  id String @id @default(uuid())

  problemId String
  problem   DSAProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  scheduledFor DateTime?
  completedAt  DateTime  @default(now())

  intervalDays Int
  wasOverdue   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([problemId])
  @@index([completedAt])
  @@index([wasOverdue])
}

enum ResumeAnalysisStatus {
  PENDING
  ANALYZED
  FAILED
}

model Resume {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileUrl  String
  fileName String?
  fileSize Int?

  targetRole String?
  version    Int

  atsScore         Int?
  roleFitScore     Int?
  keywordScore     Int?
  projectScore     Int?
  readabilityScore Int?

  extractedText  String?
  aiAnalysis     Json?
  analysisStatus ResumeAnalysisStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([atsScore])
  @@index([analysisStatus])
}

enum InterviewQuestionStatus {
  SOLVED
  PARTIAL
  FAILED
  SKIPPED
}

model InterviewSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  company   String
  role      String
  roundType InterviewRoundType @default(TECHNICAL)
  date      DateTime
  result    InterviewResult    @default(PENDING)

  sourceType InterviewSourceType @default(MANUAL)
  audioUrl   String?
  videoUrl   String?
  transcript String?

  notes          String?
  questionsAsked String[] @default([])
  topics         String[] @default([])
  conceptsMissed String[] @default([])

  whatWentWell  String?
  whatWentWrong String?
  feedback      String?

  overallScore       Float?
  confidenceScore    Float?
  communicationScore Float?
  technicalScore     Float?

  aiSummary       Json?
  actionPlan      String?
  nextActions     String[]                  @default([])
  analysisStatus  InterviewAnalysisStatus   @default(DRAFT)
  questionReplays InterviewQuestionReplay[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([userId])
  @@index([company])
  @@index([roundType])
  @@index([result])
  @@index([date])
}

model InterviewQuestionReplay {
  id String @id @default(uuid())

  interviewId String
  interview   InterviewSession @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  question            String
  userAnswer          String?
  missedPoints        String[]                @default([])
  interviewerFeedback String?
  confidenceScore     Float?
  status              InterviewQuestionStatus @default(PARTIAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewId])
  @@index([status])
}

model Streak {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  activity  String
  createdAt DateTime @default(now())

  @@unique([userId, date, activity])
}

model ReadinessScore {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dsaScore       Float    @default(0)
  resumeScore    Float    @default(0)
  interviewScore Float    @default(0)
  aptitudeScore  Float    @default(0)
  overallScore   Float    @default(0)
  readyFor       String[]
  improveFor     String[]
  updatedAt      DateTime @updatedAt
}

model ReadinessHistory {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  overallScore   Float
  dsaScore       Float
  resumeScore    Float
  interviewScore Float
  aptitudeScore  Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DailyPlan {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdDate String
  plan        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, createdDate])
  @@index([userId])
}

enum Plan {
  FREE
  PREMIUM
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

model Payment {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan     Plan          @default(PREMIUM)
  status   PaymentStatus @default(CREATED)
  amount   Int
  currency String        @default("INR")

  razorpayOrderId   String  @unique
  razorpayPaymentId String?
  razorpaySignature String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Feedback {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    FeedbackType
  status  FeedbackStatus @default(OPEN)
  subject String
  message String
  rating  Int?

  pageUrl   String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}
