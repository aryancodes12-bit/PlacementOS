generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  MENTOR
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemStatus {
  UNSOLVED
  ATTEMPTED
  SOLVED
}

enum InterviewRoundType {
  HR
  TECHNICAL
  MANAGERIAL
  APTITUDE
  GROUP_DISCUSSION
  SYSTEM_DESIGN
  CODING
  OTHER
}

enum InterviewResult {
  PENDING
  SELECTED
  REJECTED
  ON_HOLD
  NO_RESPONSE
}

enum InterviewSourceType {
  MANUAL
  AUDIO
  VIDEO
}

enum InterviewAnalysisStatus {
  DRAFT
  ANALYZED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?
  googleId  String?  @unique
  role      Role     @default(STUDENT)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile          Profile?
  dsaProblems      DSAProblem[]
  resumes          Resume[]
  interviews       InterviewSession[]
  streaks          Streak[]
  readinessScore   ReadinessScore?
  dailyPlans       DailyPlan[]
  readinessHistory ReadinessHistory[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          String[]
  targetCompanies String[]
  bio             String?
  linkedinUrl     String?
  githubUrl       String?
  college         String?
  graduationYear  Int?
}

model DSAProblem {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title      String
  topic      String
  difficulty Difficulty
  status     ProblemStatus @default(UNSOLVED)

  platform   String?
  problemUrl String?
  notes      String?

  solvedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([topic])
  @@index([difficulty])
  @@index([status])
}

enum ResumeAnalysisStatus {
  PENDING
  ANALYZED
  FAILED
}

model Resume {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileUrl  String
  fileName String?
  fileSize Int?

  targetRole String?
  version    Int

  atsScore         Int?
  roleFitScore     Int?
  keywordScore     Int?
  projectScore     Int?
  readabilityScore Int?

  extractedText  String?
  aiAnalysis     Json?
  analysisStatus ResumeAnalysisStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([atsScore])
  @@index([analysisStatus])
}

enum InterviewQuestionStatus {
  SOLVED
  PARTIAL
  FAILED
  SKIPPED
}

model InterviewSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  company   String
  role      String
  roundType InterviewRoundType @default(TECHNICAL)
  date      DateTime
  result    InterviewResult    @default(PENDING)

  sourceType InterviewSourceType @default(MANUAL)
  audioUrl   String?
  videoUrl   String?
  transcript String?

  notes          String?
  questionsAsked String[] @default([])
  topics         String[] @default([])
  conceptsMissed String[] @default([])

  whatWentWell  String?
  whatWentWrong String?
  feedback      String?

  overallScore       Float?
  confidenceScore    Float?
  communicationScore Float?
  technicalScore     Float?

  aiSummary       Json?
  actionPlan      String?
  nextActions     String[]                  @default([])
  analysisStatus  InterviewAnalysisStatus   @default(DRAFT)
  questionReplays InterviewQuestionReplay[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([userId])
  @@index([company])
  @@index([roundType])
  @@index([result])
  @@index([date])
}

model InterviewQuestionReplay {
  id String @id @default(uuid())

  interviewId String
  interview   InterviewSession @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  question            String
  userAnswer          String?
  missedPoints        String[]                @default([])
  interviewerFeedback String?
  confidenceScore     Float?
  status              InterviewQuestionStatus @default(PARTIAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewId])
  @@index([status])
}

model Streak {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  activity  String
  createdAt DateTime @default(now())

  @@unique([userId, date, activity])
}

model ReadinessScore {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dsaScore       Float    @default(0)
  resumeScore    Float    @default(0)
  interviewScore Float    @default(0)
  aptitudeScore  Float    @default(0)
  overallScore   Float    @default(0)
  readyFor       String[]
  improveFor     String[]
  updatedAt      DateTime @updatedAt
}

model ReadinessHistory {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  overallScore   Float
  dsaScore       Float
  resumeScore    Float
  interviewScore Float
  aptitudeScore  Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DailyPlan {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdDate String
  plan        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, createdDate])
  @@index([userId])
}
